# NanoBot environment configuration
#
# Copy this file to .env and fill in your values.
# .env is used by both docker compose (for image resolution) and make (for builds).
#
# NanoBot runtime secrets (API keys, tokens) are stored in the Docker volume at
# ~/.nanobot/config.json — not loaded from .env by the container.
#
# See DEPLOY.md for full setup instructions.

# ---------------------------------------------------------------------------
# Container registry (used by Makefile and docker-compose.yml)
# ---------------------------------------------------------------------------

REGISTRY=

# ---------------------------------------------------------------------------
# LLM Provider (providers.custom in config.json)
# ---------------------------------------------------------------------------

# Poe API key — https://poe.com/api_key
POE_API_KEY=

# ---------------------------------------------------------------------------
# Telegram channel (channels.telegram in config.json)
# ---------------------------------------------------------------------------

# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Your numeric Telegram user ID (whitelist) — message @userinfobot to find it
TELEGRAM_ALLOW_FROM=

# ---------------------------------------------------------------------------
# Spotify (workspace/spotify/config.json — set up via spotify.py setup)
# ---------------------------------------------------------------------------

# From your Spotify Developer App — https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Langfuse observability — https://langfuse.com
# Set LANGFUSE_BASE_URL to enable tracing; leave blank to disable.
# ---------------------------------------------------------------------------

# LANGFUSE_BASE_URL=https://cloud.langfuse.com       # EU region
# LANGFUSE_BASE_URL=https://us.cloud.langfuse.com    # US region
LANGFUSE_BASE_URL=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ---------------------------------------------------------------------------
# Google Workspace (gog skill) — https://github.com/steipete/gogcli
# Password for the file-based keyring that stores OAuth tokens in the container.
# Choose any strong password. Required if GOG_ACCOUNT is used.
# ---------------------------------------------------------------------------

GOG_KEYRING_PASSWORD=
GOG_ACCOUNT=you@gmail.com    # optional: default account for gog commands

TRELLO_API_KEY="your-api-key"
TRELLO_TOKEN="your-token"