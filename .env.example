# NanoBot environment configuration
#
# NanoBot stores its configuration in ~/.nanobot/config.json (the Docker volume).
# This file documents the values you need to populate there before starting the gateway.
#
# Copy this file to .env for reference, but note that values are set in
# ~/.nanobot/config.json — not loaded from .env by the container.
#
# See DEPLOY.md for full setup instructions.

# ---------------------------------------------------------------------------
# LLM Provider (providers.custom in config.json)
# ---------------------------------------------------------------------------

# Poe API key — https://poe.com/api_key
POE_API_KEY=

# ---------------------------------------------------------------------------
# Telegram channel (channels.telegram in config.json)
# ---------------------------------------------------------------------------

# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Your numeric Telegram user ID (whitelist) — message @userinfobot to find it
TELEGRAM_ALLOW_FROM=

# ---------------------------------------------------------------------------
# Spotify (workspace/spotify/config.json — set up via spotify.py setup)
# ---------------------------------------------------------------------------

# From your Spotify Developer App — https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
